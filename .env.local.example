# PostgreSQL connection string from Railway
DATABASE_URL=postgresql://user:password@host.railway.app:5432/railway

# OpenAI API key (server-side only — never exposed to browser)
OPENAI_API_KEY=sk-...

# Admin password for CRM login
ADMIN_PASSWORD=your-secure-password-here

# Session encryption secret — must be at least 32 characters
SESSION_SECRET=at-least-32-chars-random-secret-string-here-change-this
