# From Railway PostgreSQL service
DATABASE_URL=postgresql://postgres:xxx@xxx.railway.app:5432/railway

# OpenAI
OPENAI_API_KEY=sk-...

# Admin login password
ADMIN_PASSWORD=your-secure-password-here

# JWT signing secret — must be 32+ chars, keep it secret
SESSION_SECRET=at-least-32-chars-random-string-here-change-this

# Allowed frontend origin for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Railway sets PORT automatically — don't set this locally
# PORT=4000
